// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Toko {
    id String @id @default(uuid())
    namaToko String
    logoToko String?
    logoTokoId String?
    alamat String
    noTelp String
    SubscribeTime DateTime
    User User[]
    Voucher Voucher[]
    Member Member[]
    Downline Downline[]
    Aksesoris Aksesoris[]
    Sparepart SparePart[]
    TransaksiSparepart TransaksiSparepat[]
    ItemTransaksiSparepart ItemsTransaksiSparepart[]
    TransaksiVoucherHarian TransaksiVoucherHarian[]
    TransaksiVoucherDownline TransaksiVoucherDownline[]
    ItemTransaksiVoucherDownline ItemsTransaksiVoucherDownline[]
    TransaksiAksesoris TransaksiAksesoris[]
    ItemTransaksiAksesoris ItemsTransaksiAksesoris[]
    UangModal UangModal[]
    ServiceHP ServiceHP[]
    SparepartServiceHP SparepartServiceHP[]
    Log Log[]
    JualanHarian JualanHarian[]
    KejadianTakTerduga KejadianTakTerduga[]
    Keuntungan Keuntungan[]
    DataMember DataMember[]
    isActive Boolean @default(true)   // ✅ TAMBAHAN
    createdAt DateTime? @default(now())
    updatedAt DateTime? @updatedAt

}

model Keuntungan {
  id                       String   @id @default(uuid())
  idToko                   String
  tanggal                  DateTime

  keuntunganTransaksi      BigInt   @default(0)
  keuntunganVoucherHarian  BigInt   @default(0)
  keuntunganAcc            BigInt   @default(0)
  keuntunganSparepart      BigInt   @default(0)
  keuntunganService        BigInt   @default(0)
  keuntunganGrosirVoucher  BigInt   @default(0)

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  Toko                     Toko     @relation(fields: [idToko], references: [id])

  @@unique([idToko, tanggal])
}

model User {
    id String @id @default(uuid())
    nama String
    email String @unique
    password String
    role String
    penempatan String?
    createdAt DateTime? @default(now())
    updatedAt DateTime? @updatedAt
    idToko String
    isActive Boolean @default(true)   // ✅ TAMBAHAN
    Toko          Toko @relation(fields: [idToko], references: [id])

}

model Member {
    id String @id @default(uuid())
    nama String
    noTelp String @unique
    kodeMember String @unique
    createdAt DateTime? @default(now())
    updatedAt DateTime? @updatedAt
    JualanHarian JualanHarian[]
    TransaksiAksesoris TransaksiAksesoris[]
    TransaksiSparepart TransaksiSparepat[]
    ServiceHP ServiceHP[]
    VoucherHarian TransaksiVoucherHarian[]
    DataMember DataMember[]

    idToko String
    Toko          Toko @relation(fields: [idToko], references: [id])
}

model DataMember {
      id String @id @default(uuid())
      idToko String
      nama String
      nomor String
      idMember String?
      Member        Member? @relation(fields: [idMember], references: [id])
      Toko          Toko @relation(fields: [idToko], references: [id])

}

model Downline {
  id String @id @default(uuid())
  nama String
  kodeDownline String @unique
  noHp String?
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  transaksiVoucherDownline TransaksiVoucherDownline[]
  idToko String
  isActive Boolean @default(true)   // ✅ TAMBAHAN
  Toko          Toko @relation(fields: [idToko], references: [id])
}

model Voucher {
  id String @id @default(uuid())
  nama String
  brand String
  stok Int
  hargaPokok Int?
  hargaJual Int?
  hargaEceran Int?
  penempatan String
  ItemsTransaksiVoucherDownline ItemsTransaksiVoucherDownline[]
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  TransaksiVoucherHarian TransaksiVoucherHarian[]
  idToko String
  Toko          Toko @relation(fields: [idToko], references: [id])
  isActive Boolean @default(true)   // ✅ TAMBAHAN
}

model Aksesoris {
  id String @id @default(uuid())
  barcode String @unique
  nama String
  kategori String
  brand String
  stok Int
  hargaModal Int
  penempatan String
  hargaJual Int
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  ItemsTransaksiAksesoris ItemsTransaksiAksesoris[]
  idToko String
  Toko          Toko @relation(fields: [idToko], references: [id])
  isActive Boolean @default(true)   // ✅ TAMBAHAN
}

model SparePart {
  id String @id @default(uuid())
  barcode String @unique
  nama String
  kategori String
  brand String
  stok Int
  hargaModal Int
  hargaJual Int
  penempatan String
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  ItemsTransaksiSparepart ItemsTransaksiSparepart[]
  SparepartService SparepartServiceHP[]
  idToko String
  Toko          Toko @relation(fields: [idToko], references: [id])
  isActive Boolean @default(true)   // ✅ TAMBAHAN

}

model TransaksiSparepat {
  id String @id @default(uuid())
  namaPembeli String?
  idToko String
  idMember String?
  totalHarga Int
  tanggal DateTime
  keuntungan Int
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
  items ItemsTransaksiSparepart[]
  Member          Member? @relation(fields: [idMember], references: [id])
  Toko            Toko @relation(fields: [idToko], references: [id])

}

model ItemsTransaksiSparepart {
  id String @id @default(uuid())
  idTransaksi String
  idSparepart String
  tanggal DateTime?
  quantity Int
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
  TransaksiSparepart TransaksiSparepat @relation(fields: [idTransaksi], references: [id])
  Sparepart SparePart @relation(fields: [idSparepart], references: [id])
  idToko String
  Toko          Toko @relation(fields: [idToko], references: [id])

}

model TransaksiVoucherHarian {
  id String @id @default(uuid())
  idVoucher String
  idMember String?
  keuntungan Int
  Voucher Voucher @relation(fields: [idVoucher], references: [id])
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
  idToko String
  Toko          Toko @relation(fields: [idToko], references: [id])
  Member        Member? @relation(fields: [idMember], references: [id])

}

model TransaksiVoucherDownline {
  id String @id @default(uuid())
  kodeDownline String?
  totalHarga Int
  tanggal DateTime
  keuntungan Int?
  status String
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
  downline Downline? @relation(fields: [kodeDownline], references: [kodeDownline])
  items ItemsTransaksiVoucherDownline[]
  idToko String
  Toko          Toko @relation(fields: [idToko], references: [id])


}

model ItemsTransaksiVoucherDownline {
  id String @id @default(uuid())
  idTransaksi String
  idVoucher String
  tanggal DateTime?
  quantity Int
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
  transaksi TransaksiVoucherDownline @relation(fields: [idTransaksi], references: [id])
  Voucher Voucher @relation(fields: [idVoucher], references: [id])
  idToko String
  Toko          Toko @relation(fields: [idToko], references: [id])

}

model TransaksiAksesoris {
  id String @id @default(uuid())
  namaPembeli String?
  totalHarga Int
  tanggal DateTime
  keuntungan Int?
  status String
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?

  items ItemsTransaksiAksesoris[]
  idMember String?
  Member          Member? @relation(fields: [idMember], references: [id])
  idToko String
  Toko          Toko @relation(fields: [idToko], references: [id])

}

model ItemsTransaksiAksesoris {
  id String @id @default(uuid())
  idTransaksi String
  idAksesoris String
  quantity Int
  tanggal DateTime?
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
  TransaksiAksesoris TransaksiAksesoris @relation(fields: [idTransaksi], references: [id])
  Aksesoris Aksesoris @relation(fields: [idAksesoris], references: [id])
  idToko String
  Toko          Toko @relation(fields: [idToko], references: [id])

}

model UangModal {
  id String @id @default(uuid())
  keterangan String
  tanggal DateTime
  jumlah Int
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  idToko String
  Toko          Toko @relation(fields: [idToko], references: [id])

}

model ServiceHP {
  id String @id @default(uuid())
  brandHP String 
  keterangan String
  tanggal DateTime
  namaPelangan String?
  status String
  hargaSparePart Int?
  noHP String
  biayaJasa Int
  keuntungan Int
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
  Sparepart SparepartServiceHP[]
  idMember String?
  Member          Member? @relation(fields: [idMember], references: [id])
  idToko String
  Toko          Toko @relation(fields: [idToko], references: [id])


}

model SparepartServiceHP {
    id String @id @default(uuid())
    idServiceHP String
    idSparepart String
    quantity Int
    tanggal DateTime?
    createdAt DateTime? @default(now())
    updatedAt DateTime? @updatedAt
    deletedAt DateTime?
    ServiveHP ServiceHP  @relation(fields: [idServiceHP], references: [id])
    Sparepart SparePart  @relation(fields: [idSparepart], references: [id])
    idToko String
    Toko          Toko @relation(fields: [idToko], references: [id])

}


model Log {
    id String @id @default(uuid())
    kategori String
    keterangan String
    nama String
    nominal Int?
    createdAt DateTime? @default(now())
    updatedAt DateTime? @updatedAt
    idToko String
    Toko          Toko @relation(fields: [idToko], references: [id])

}


model JualanHarian {
      id String @id @default(uuid())
      kategori String
      nominal Int?
      tanggal DateTime
      createdAt DateTime? @default(now())
      updatedAt DateTime? @updatedAt
      deletedAt DateTime?
      idMember String?
      Member          Member? @relation(fields: [idMember], references: [id])
      idToko String
      Toko          Toko @relation(fields: [idToko], references: [id])


}


model KejadianTakTerduga {
      id String @id @default(uuid())
      nominal Int
      no_transaksi Int
      keterangan String
      tanggal DateTime
      createdAt DateTime? @default(now())
      updatedAt DateTime? @updatedAt
      idToko String
      Toko          Toko @relation(fields: [idToko], references: [id])
}